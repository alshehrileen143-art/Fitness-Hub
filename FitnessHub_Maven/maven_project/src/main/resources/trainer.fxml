<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #333333;" stylesheets="@todo.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="trainerController">
   <children>
      <Label layoutX="263.0" layoutY="24.0" prefHeight="37.0" prefWidth="222.0" text="TRAINER DASHBOARD" textFill="#e4dede">
         <font>
            <Font name="Britannic Bold" size="22.0" />
         </font>
      </Label>
      <TableView fx:id="membersListTable" layoutX="453.0" layoutY="318.0" prefHeight="257.0" prefWidth="294.0" style="-fx-background-color: #666666;">
        <columns>
          <TableColumn fx:id="memberNameColumn" prefWidth="293.0" style="-fx-background-color: #666666;" text="username" />
        </columns>
      </TableView>
      <Label layoutX="528.0" layoutY="268.0" prefHeight="37.0" prefWidth="215.0" text="List of Members" textFill="#e4dede">
         <font>
            <Font name="Britannic Bold" size="19.0" />
         </font>
      </Label>
      <Label layoutX="565.0" layoutY="32.0" prefHeight="37.0" prefWidth="221.0" text="Assign Workouts" textFill="#e4dede">
         <font>
            <Font name="Britannic Bold" size="19.0" />
         </font>
      </Label>
      <TextField fx:id="usernameField" layoutX="525.0" layoutY="84.0" prefHeight="25.0" prefWidth="221.0" promptText="enter username" styleClass="textinput" />
      <TextField fx:id="workoutField" layoutX="525.0" layoutY="124.0" prefHeight="25.0" prefWidth="221.0" promptText="enter workout" styleClass="textinput" />
      <Label fx:id="workoutLabel" layoutX="530.0" layoutY="166.0" prefHeight="17.0" prefWidth="221.0" text="assigned successfully" textFill="WHITE" />
      <Button fx:id="addNewWorkout" layoutX="539.0" layoutY="196.0" mnemonicParsing="false" onAction="#addWorkoutButtonOnAction" prefHeight="35.0" prefWidth="199.0" text="ASSIGN WORKOUT" textFill="WHITE">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Button>
      <Button fx:id="trainerLogout" layoutX="3.0" layoutY="550.0" mnemonicParsing="false" onAction="#trainerLogoutButtonOnAction" prefHeight="42.0" prefWidth="105.0" text="Logout" textFill="#e8dfdf">
         <font>
            <Font name="System Bold" size="19.0" />
         </font>
      </Button>
      <Label layoutX="127.0" layoutY="231.0" prefHeight="37.0" prefWidth="221.0" text="Slot Bookings" textFill="#e4dede">
         <font>
            <Font name="Britannic Bold" size="19.0" />
         </font>
      </Label>
      <TableView fx:id="slotBookingTable" layoutX="14.0" layoutY="268.0" prefHeight="277.0" prefWidth="358.0" style="-fx-background-color: #666666;">
        <columns>
          <TableColumn fx:id="timeColumn" prefWidth="86.0" style="-fx-background-color: #666666;" text="time" />
          <TableColumn fx:id="dayColumn" prefWidth="103.0" style="-fx-background-color: #666666;" text="day" />
            <TableColumn fx:id="memberColumn" prefWidth="168.0" style="-fx-background-color: #666666;" text="member" />
        </columns>
      </TableView>
      <Label layoutX="56.0" layoutY="43.0" prefHeight="37.0" prefWidth="221.0" text="Create new slot" textFill="#e4dede">
         <font>
            <Font name="Britannic Bold" size="19.0" />
         </font>
      </Label>
      <TextField fx:id="enterTimeField" layoutX="14.0" layoutY="85.0" prefHeight="25.0" prefWidth="224.0" promptText="enter time (1 - 23 ) hrs" styleClass="textinput" />
      <TextField fx:id="enterDayField" layoutX="12.0" layoutY="124.0" prefHeight="25.0" prefWidth="225.0" promptText="enter day (1 - 7) " styleClass="textinput" />
      <Button fx:id="createSlotButton" layoutX="13.0" layoutY="179.0" mnemonicParsing="false" onAction="#createSlotButtonOnAction" prefHeight="35.0" prefWidth="226.0" text="Create Slot" textFill="WHITE">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Button>
      <Label fx:id="createSlotLabel" layoutX="11.0" layoutY="159.0" prefHeight="17.0" prefWidth="221.0" text="assigned successfully" textFill="WHITE" />
   </children>
</AnchorPane>
